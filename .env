# Frontend Environment Variables
FRONTEND_PORT=4200

# Backend Environment Variables
BACKEND_PORT=5050
ASPNETCORE_ENVIRONMENT=Production

# Database Connection (Adjust according to your needs)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=formcraft
# The connection string uses the service name "db" from docker-compose.yml
DB_CONNECTION_STRING=Server=db;Database=formcraft;User=root;Password=root_password;
